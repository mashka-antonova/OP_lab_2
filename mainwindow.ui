    <item row="1" column="0">
     <widget class="QTableWidget" name="tableWidget">
      <property name="styleSheet">
       <string notr="true">/* 1. Общая область вертикальной полосы прокрутки */
QScrollBar:vertical {
    background-color: #000000; /* Фон дорожки */
    width: 16px;
    margin: 0px 0px 0px 0px;
    border: 1px solid #00FF00; /* Зеленая рамка всей полосы */
}

/* 2. Сам ползунок (бегунок) */
QScrollBar::handle:vertical {
    background-color: #00FF00; /* Ярко-зеленый ползунок */
    min-height: 20px;
    margin: 2px; /* Небольшой отступ внутри рамки */
}

/* 3. Нижняя и верхняя кнопки (стрелочки) — полностью их убираем */
QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical {
    background: none;
    height: 0px;
    subcontrol-origin: margin;
}

/* 4. Область дорожки выше и ниже ползунка (важно!) */
QScrollBar::add-page:vertical, QScrollBar::sub-page:vertical {
    background: #000000; /* Чтобы область под ползунком была черной, а не серой */
}

/* 5. То же самое для горизонтальной полосы (на всякий случай) */
QScrollBar:horizontal {
    background-color: #000000;
    height: 16px;
    border: 1px solid #00FF00;
}
QScrollBar::handle:horizontal {
    background-color: #00FF00;
    min-width: 20px;
    margin: 2px;
}
QScrollBar::add-line:horizontal, QScrollBar::sub-line:horizontal,
QScrollBar::add-page:horizontal, QScrollBar::sub-page:horizontal {
    background: none;
    width: 0px;
}</string>
      </property>
     </widget>
